generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  password          String
  image             String?
  bio               String?
  website           String?
  twitter           String?
  consentAcceptedAt DateTime? // Added for compliance tracking
  vlogs             Vlog[]
  likes             Like[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Other models (Vlog, Like) follow the design docs...