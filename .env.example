# =============================================================================
# Snapora — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local to git.
# =============================================================================

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres@localhost:5432/snapora_dev"

# NextAuth.js / Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Cloudinary — cover images and profile avatars
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Logging (optional)
LOG_LEVEL="info"
